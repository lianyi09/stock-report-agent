# 美股日报邮件发送配置
# 复制此文件为 .env 并填入你的配置值

# Resend API Key（从 https://resend.com 获取）
RESEND_API_KEY=re_xxxxxxxx

# 发件人邮箱（需在 Resend 中验证的域名邮箱）
# 开发测试阶段可使用 Resend 提供的默认发件人: onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev

# 发件人名称
RESEND_FROM_NAME=美股日报

# 收件人邮箱（你的接收邮箱）
RESEND_RECIPIENT=your-email@example.com
